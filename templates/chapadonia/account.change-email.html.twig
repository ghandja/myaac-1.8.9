<div class="row justify-content-center">
	<div class="col-md-6">
		<div class="card rasta-card">
			<div class="card-header">
				<h4 class="mb-0">Alterar Email</h4>
			</div>
			<div class="card-body">
				<form action="{{ getLink('account/change-email') }}" method="post">
					{{ csrf() }}
					<input type="hidden" name="changeemailsave" value="1">
					<div class="mb-3">
						<label class="form-label text-light fw-bold">Novo Email:</label>
						<input type="email" name="new_email" class="form-control" maxlength="255">
					</div>
					<div class="mb-3">
						<label class="form-label text-light fw-bold">Senha:</label>
						<input type="password" name="password" class="form-control" maxlength="29">
					</div>
					<button type="submit" class="btn btn-leaf">Alterar Email</button>
					<a href="{{ getLink('account/manage') }}" class="btn btn-outline-light ms-2">Voltar</a>
				</form>
			</div>
		</div>
	</div>
</div>
